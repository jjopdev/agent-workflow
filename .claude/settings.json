{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(bun *)",
      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(jest *)",
      "Bash(vitest *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(poetry *)",
      "Bash(uv *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(kubectl *)",
      "Bash(terraform *)",
      "Bash(aws *)",
      "Bash(gcloud *)",
      "Bash(az *)",
      "Bash(dotnet *)",
      "Bash(msbuild *)",
      "Bash(nuget *)",
      "Bash(snyk *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(env)",
      "Bash(date)",
      "Bash(whoami)",
      "Bash(* --version)",
      "Bash(* --help)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:owasp.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:nuget.org)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf .)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(git push * --force)",
      "Bash(git push * -f)",
      "Bash(git reset --hard)",
      "Bash(git clean -fd *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(telnet *)",
      "Bash(nmap *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.gnupg/**)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.profile)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)"
    ]
  },

  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["docker", "docker-compose"],
    "filesystem": {
      "allowWrite": [
        "//tmp",
        "~/.npm",
        "~/.cache"
      ],
      "denyWrite": [
        "//etc",
        "//usr",
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.bashrc",
        "~/.zshrc",
        "~/.profile"
      ],
      "denyRead": [
        "~/.ssh/id_*",
        "~/.aws/credentials",
        "~/.gnupg/private-keys-v1.d"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "api.github.com",
        "registry.npmjs.org",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "*.pypi.org",
        "crates.io",
        "*.crates.io",
        "proxy.golang.org",
        "docs.anthropic.com",
        "code.claude.com",
        "api.nuget.org",
        "nuget.org",
        "*.nuget.org",
        "learn.microsoft.com",
        "owasp.org",
        "*.owasp.org",
        "developer.mozilla.org",
        "stackoverflow.com"
      ],
      "allowLocalBinding": true
    }
  },

  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Check if the file .claude/progress.md exists in the current working directory.\n\nIf it exists, read it and respond with:\n{\"systemMessage\":\"📋 Work in progress found. Run /save-progress to update or delete .claude/progress.md when done.\"}\n\nIf it does not exist, respond with: {}",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "You are a lesson-detection hook for the agent workflow.\n\nInput:\n$ARGUMENTS\n\n## Decision logic\n\n1. Parse the input JSON. If `stop_hook_active` is `true`, respond with ONLY `{}` to prevent infinite loops.\n\n2. Analyze `last_assistant_message` for evidence that Claude was corrected by the user or that an approach failed:\n   - Claude acknowledging a mistake: 'I apologize', 'you are right', 'that was incorrect', 'my mistake'\n   - Retry after failure: 'let me try a different approach', 'that did not work', 'the previous attempt failed'\n   - Responding to a user correction: addressing user's 'no', 'wrong', 'not that', 'instead do'\n\n   Do NOT flag: normal bug fixes the user requested, standard iterative implementation, or expected error handling.\n\n3. If evidence of correction or failure is found, respond with ONLY:\n{\"decision\":\"block\",\"reason\":\"Correction or failure detected. Append a lesson to .claude/skills/workflow-knowledge/lessons.md with format: - **[CATEGORY]** Actionable takeaway. Categories: [DX], [ARCH], [SECURITY], [FAIL], [PERF]. Then stop.\"}\n\n4. If no evidence is found, respond with ONLY: {}",
            "timeout": 30
          }
        ]
      }
    ]
  },

  "autoUpdatesChannel": "stable",
  "includeCoAuthoredBy": false,
  "cleanupPeriodDays": 30
}
